generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
    provider     = "mysql"
    url          = env("DATABASE_URL")
    relationMode = "prisma"
}

model Season {
    id        Int        @id @default(autoincrement())
    name      String     @db.VarChar(255)
    matchdays Matchday[]
    teams     Team[]
}

model Matchday {
    id       Int    @id @default(autoincrement())
    seasonId Int
    matchday Int
    season   Season @relation(fields: [seasonId], references: [id])
    games    Game[]
}

model Team {
    id       Int      @id @default(autoincrement())
    name     String   @unique @db.VarChar(255)
    seasons  Season[]
    players  Player[]
    homeTeam Game[]   @relation("HomeTeam")
    awayTeam Game[]   @relation("AwayTeam")
}

model Game {
    id         Int      @id @default(autoincrement())
    matchdayId Int
    gamenumber Int
    homeTeamId Int
    awayTeamId Int
    date       String
    homePoints Int?
    awayPoints Int?
    penalty    Boolean  @default(false)
    matchday   Matchday @relation(fields: [matchdayId], references: [id])
    homeTeam   Team     @relation("HomeTeam", fields: [homeTeamId], references: [id])
    awayTeam   Team     @relation("AwayTeam", fields: [awayTeamId], references: [id])
    playerStats  PlayerStats[]

    @@unique([matchdayId, gamenumber], name: "UniqueMatchdayGamenumber")
}

model Player {
    id           Int          @id @default(autoincrement())
    playernumber String       @default("")
    firstname    String
    lastname     String
    teamId       Int
    team         Team         @relation(fields: [teamId], references: [id])
    active       Boolean      @default(true)
    memberships  Membership[]
    playerStats  PlayerStats[]
}

model PlayerStats {
    id         Int     @id @default(autoincrement())
    over100    Int     @default(0)
    over140    Int     @default(0)
    over180    Int     @default(0)
    highFinish Int     @default(0)
    playerId   Int
    player     Player? @relation(fields: [playerId], references: [id])
    gameId     Int
    game       Game?   @relation(fields: [gameId], references: [id])

    @@unique([gameId, playerId], name: "UniqueGamePlayer")
}

model Membership {
    id       Int     @id @default(autoincrement())
    playerId Int     @unique
    month    Int
    payed    Boolean
    player   Player  @relation(fields: [playerId], references: [id])
}

model KeepDbAlive {
    id   Int    @id @default(autoincrement())
    date String
}

model User {
    id            String    @id @default(cuid())
    name          String?
    username      String?   @unique
    email         String?   @unique
    emailVerified DateTime?
    password      String?
    image         String?
    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @updatedAt
}
