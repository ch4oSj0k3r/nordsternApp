generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model Season {
  id        Int        @id @default(autoincrement())
  name      String     @db.VarChar(255)
  matchdays Matchday[]
  teams     Team[]
}

model Matchday {
  id       Int    @id @default(autoincrement())
  seasonId Int
  matchday Int
  season   Season @relation(fields: [seasonId], references: [id])
  games    Game[]
}

model Team {
  id       Int      @id @default(autoincrement())
  name     String   @unique @db.VarChar(255)
  seasons  Season[]
  players  Player[]
  homeTeam Game[]   @relation("HomeTeam")
  awayTeam Game[]   @relation("AwayTeam")
}

model Game {
  id         Int      @id @default(autoincrement())
  matchdayId Int
  gamenumber Int
  homeTeamId Int
  awayTeamId Int
  date       String
  homePoints Int?
  awayPoints Int?
  penalty    Boolean  @default(false)
  matchday   Matchday @relation(fields: [matchdayId], references: [id])
  homeTeam   Team     @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam   Team     @relation("AwayTeam", fields: [awayTeamId], references: [id])

  @@unique([matchdayId, gamenumber], name: "UniqueMatchdayGamenumber")
}

model Player {
  id          Int          @id @default(autoincrement())
  firstname   String
  lastname    String
  teamId      Int
  team        Team         @relation(fields: [teamId], references: [id])
  memberships Membership[]
  playerStats PlayerStats?
}

model PlayerStats {
  id         Int     @id @default(autoincrement())
  over100    Int
  over140    Int
  over180    Int
  highFinish Int
  playerId   Int     @unique
  player     Player? @relation(fields: [playerId], references: [id])
}

model Membership {
  id       Int     @id @default(autoincrement())
  playerId Int     @unique
  month    Int
  payed    Boolean
  player   Player  @relation(fields: [playerId], references: [id])
}

model KeepDbAlive {
  id   Int    @id @default(autoincrement())
  date String
}

model SeasonToTeam {
  A Int
  B Int

  @@unique([A, B], map: "_SeasonToTeam_AB_unique")
  @@index([B], map: "_SeasonToTeam_B_index")
  @@map("_SeasonToTeam")
}

model Account {
  id                 String    @id @default(cuid())
  userId             String
  providerType       String
  providerId         String
  providerAccountId  String
  refreshToken       String?
  accessToken        String?
  accessTokenExpires DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user               User      @relation(fields: [userId], references: [id])
  @@unique([providerId, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}