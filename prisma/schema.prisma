// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider             = "mysql"
  url                  = env("DATABASE_URL")
  referentialIntegrity = "prisma"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["referentialIntegrity"]
}

model Season {
  id        Int        @id @default(autoincrement())
  name      String     @db.VarChar(255)
  matchdays Matchday[]
  teams     Team[]
}

model Matchday {
  id       Int    @id @default(autoincrement())
  season   Season @relation(fields: [seasonId], references: [id])
  seasonId Int
  matchday Int
  games    Game[]
}

model Team {
  id       Int      @id @default(autoincrement())
  name     String   @unique @db.VarChar(255)
  seasons  Season[]
  players  Player[]
  homeTeam Game[]   @relation("HomeTeam")
  awayTeam Game[]   @relation("AwayTeam")
}

model Game {
  id         Int      @id @default(autoincrement())
  matchday   Matchday @relation(fields: [matchdayId], references: [id])
  matchdayId Int
  gamenumber Int
  homeTeam   Team     @relation(name: "HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam   Team     @relation(name: "AwayTeam", fields: [awayTeamId], references: [id])
  homeTeamId Int
  awayTeamId Int
  date       String
  homePoints Int?
  awayPoints Int?

  @@unique([matchdayId, gamenumber], name: "UniqueMatchdayGamenumber")
}

model Player {
  id          Int          @id @default(autoincrement())
  firstname   String
  lastname    String
  teamId      Int
  team        Team         @relation(fields: [teamId], references: [id])
  memberships Membership[]
  playerStats PlayerStats?
}

model PlayerStats {
  id         Int     @id @default(autoincrement())
  over100    Int
  over140    Int
  over180    Int
  highFinish Int
  playerId   Int     @unique
  player     Player? @relation(fields: [playerId], references: [id])
}

model Membership {
  id       Int     @id @default(autoincrement())
  playerId Int     @unique
  player   Player  @relation(fields: [playerId], references: [id])
  month    Int
  payed    Boolean
}

model KeepDbAlive {
  id   Int    @id @default(autoincrement())
  date String
}
